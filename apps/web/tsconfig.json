{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@marketplace/shared": ["../../packages/shared/src"],
      "@marketplace/shared/*": ["../../packages/shared/src/*"],
      "@marketplace/ui-react": ["../../packages/ui-react/src"],
      "@marketplace/ui-react/*": ["../../packages/ui-react/src/*"],
      "@marketplace/i18n": ["../../packages/i18n/src"],
      "@marketplace/config/*": ["../../packages/config/*"]
    }
  },
  "include": ["src/**/*", "../../packages/ui-react/src/**/*"],
  "exclude": ["node_modules"]
}

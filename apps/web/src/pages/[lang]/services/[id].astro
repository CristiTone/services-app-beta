---
/**
 * Service detail page - single service by id
 */
import Layout from '../../../../layouts/Layout.astro';
import ServiceDetail from '../../../../components/ServiceDetail';
const { lang, id } = Astro.params;
const locale = lang === 'ro' ? 'ro' : 'en';
---
<Layout locale={locale} title="Service - Marketplace">
  <ServiceDetail client:load serviceId={id ?? ''} locale={locale} />
</Layout>

---
/**
 * Home page with locale: /en or /ro
 */
import Layout from '@/layouts/Layout.astro';

const { lang } = Astro.params;
const locale = lang === 'ro' ? 'ro' : 'en';

const t = {
  en: {
    title: 'Marketplace — Find Local Professionals',
    hero_headline: 'Find the perfect professional\nfor any job',
    hero_sub: 'Hire trusted local experts — from plumbers to designers — quickly and safely.',
    hero_cta: 'Explore Services',
    hero_cta2: 'Become a Provider',
    categories_title: 'Popular Categories',
    categories: [
      { icon: '🔧', label: 'Plumbing' },
      { icon: '⚡', label: 'Electrical' },
      { icon: '🏠', label: 'Cleaning' },
      { icon: '🎨', label: 'Design' },
      { icon: '💻', label: 'Programming' },
      { icon: '📸', label: 'Photography' },
      { icon: '🌿', label: 'Gardening' },
      { icon: '🚗', label: 'Automotive' },
    ],
    how_title: 'How It Works',
    steps: [
      { num: '1', title: 'Post a request', desc: 'Describe what you need done and set your budget.' },
      { num: '2', title: 'Browse providers', desc: 'Compare profiles, reviews, and prices side by side.' },
      { num: '3', title: 'Hire & pay safely', desc: 'Payment is only released when you approve the work.' },
    ],
    cta_headline: 'Ready to get started?',
    cta_sub: 'Thousands of professionals are waiting for you.',
    cta_btn: 'Browse Services',
  },
  ro: {
    title: 'Marketplace — Găsește Profesioniști Locali',
    hero_headline: 'Găsește profesionistul perfect\npentru orice job',
    hero_sub: 'Angajează experți locali de încredere — de la instalatori la designeri — rapid și sigur.',
    hero_cta: 'Explorează Servicii',
    hero_cta2: 'Devino Furnizor',
    categories_title: 'Categorii Populare',
    categories: [
      { icon: '🔧', label: 'Instalații' },
      { icon: '⚡', label: 'Electricitate' },
      { icon: '🏠', label: 'Curățenie' },
      { icon: '🎨', label: 'Design' },
      { icon: '💻', label: 'Programare' },
      { icon: '📸', label: 'Fotografie' },
      { icon: '🌿', label: 'Grădinărit' },
      { icon: '🚗', label: 'Auto' },
    ],
    how_title: 'Cum Funcționează',
    steps: [
      { num: '1', title: 'Postează o cerere', desc: 'Descrie ce ai nevoie și stabilește bugetul.' },
      { num: '2', title: 'Răsfoiește furnizorii', desc: 'Compară profiluri, recenzii și prețuri.' },
      { num: '3', title: 'Angajează și plătește sigur', desc: 'Plata se eliberează doar la aprobarea ta.' },
    ],
    cta_headline: 'Gata să începi?',
    cta_sub: 'Mii de profesioniști te așteaptă.',
    cta_btn: 'Răsfoiește Servicii',
  },
}[locale];
---

<Layout locale={locale} title={t.title} fullWidth>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-sky-600 to-sky-800 px-4 py-24 text-white">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-4xl font-bold leading-tight sm:text-5xl lg:text-6xl">
        {t.hero_headline.split('\n').map((line, i) => (
          <span>{i > 0 && <br class="hidden sm:block" />}{line}</span>
        ))}
      </h1>
      <p class="mt-5 text-lg text-sky-100 sm:text-xl">{t.hero_sub}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href={`/${locale}/services`}
          class="rounded-lg bg-white px-6 py-3 font-semibold text-sky-700 shadow-md transition hover:bg-sky-50"
        >
          {t.hero_cta}
        </a>
        <a
          href={`/${locale}/services`}
          class="rounded-lg border border-white/60 px-6 py-3 font-semibold text-white transition hover:bg-white/10"
        >
          {t.hero_cta2}
        </a>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="mb-8 text-center text-2xl font-bold text-slate-900">{t.categories_title}</h2>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-8">
      {t.categories.map((cat) => (
        <a
          href={`/${locale}/services`}
          class="flex flex-col items-center gap-2 rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm transition hover:border-sky-400 hover:shadow-md"
        >
          <span class="text-3xl">{cat.icon}</span>
          <span class="text-sm font-medium text-slate-700">{cat.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-slate-100 px-4 py-16">
    <div class="mx-auto max-w-4xl">
      <h2 class="mb-12 text-center text-2xl font-bold text-slate-900">{t.how_title}</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {t.steps.map((step) => (
          <div class="flex flex-col items-center text-center">
            <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-sky-600 text-xl font-bold text-white shadow-md">
              {step.num}
            </div>
            <h3 class="mb-2 font-semibold text-slate-900">{step.title}</h3>
            <p class="text-sm text-slate-600">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA banner -->
  <section class="mx-auto max-w-6xl px-4 py-20 text-center">
    <h2 class="text-3xl font-bold text-slate-900 sm:text-4xl">{t.cta_headline}</h2>
    <p class="mt-3 text-slate-500">{t.cta_sub}</p>
    <a
      href={`/${locale}/services`}
      class="mt-8 inline-block rounded-lg bg-marketplace-primary px-8 py-3 font-semibold text-white shadow transition hover:bg-sky-600"
    >
      {t.cta_btn}
    </a>
  </section>

</Layout>

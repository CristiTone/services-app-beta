---
/**
 * Home page - default locale (en) at /
 */
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Marketplace - Home">
  <h1 class="text-3xl font-bold text-slate-900">Welcome to the Marketplace</h1>
  <p class="mt-2 text-slate-600">
    Find plumbers, electricians, nail technicians, and more.
  </p>
  <a
    href="/en/services"
    class="mt-4 inline-block rounded-lg bg-marketplace-primary px-4 py-2 font-medium text-white"
  >
    Browse services
  </a>
</Layout>

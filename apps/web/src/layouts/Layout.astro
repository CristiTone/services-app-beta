---
/**
 * Base layout - i18n locale and API URL for client-side config
 */
import '../styles/global.css';
import { ClientConfig } from '../components/ClientConfig';
const { locale = 'en', title = 'Marketplace' } = Astro.props;
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---
<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <ClientConfig client:load apiUrl={apiUrl} locale={locale as 'en' | 'ro'} />
    <nav class="border-b border-slate-200 bg-white px-4 py-3">
      <div class="mx-auto flex max-w-6xl items-center gap-4">
        <a href={`/${locale}`} class="font-semibold text-marketplace-primary">Marketplace</a>
        <a href={`/${locale}/services`} class="text-slate-600 hover:text-slate-900">Services</a>
        <div class="ml-auto flex gap-2">
          <a href="/en" class={locale === 'en' ? 'font-medium' : 'text-slate-500'}>EN</a>
          <span class="text-slate-300">|</span>
          <a href="/ro" class={locale === 'ro' ? 'font-medium' : 'text-slate-500'}>RO</a>
        </div>
      </div>
    </nav>
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
  </body>
</html>

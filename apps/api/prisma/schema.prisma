// Prisma schema for PostgreSQL - services marketplace
// Run: pnpm db:generate (from root) and pnpm db:push to sync

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   // "customer" | "provider"
  createdAt DateTime @default(now())
  services  Service[]
  bookings  Booking[] @relation("CustomerBookings")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  providerId  String
  provider    User     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  createdAt   DateTime @default(now())

  @@index([providerId])
}

model Booking {
  id         String   @id @default(cuid())
  serviceId  String
  customerId String
  date       DateTime
  status     String   // "pending" | "confirmed" | "completed" | "cancelled"
  createdAt  DateTime @default(now())
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  customer   User     @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([customerId])
}

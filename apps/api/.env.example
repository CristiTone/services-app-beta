# PostgreSQL connection string
# On Railway: set to the Railway PostgreSQL service URL (auto-provided as DATABASE_URL)
DATABASE_URL="postgresql://user:password@localhost:5432/marketplace?schema=public"

# JWT secret for auth middleware (generate a secure random string)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# API server port (Railway sets this automatically)
PORT=3000

# Comma-separated list of allowed CORS origins in production
# e.g. CORS_ORIGIN="https://your-web-app.up.railway.app"
CORS_ORIGIN=

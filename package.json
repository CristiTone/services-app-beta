{
  "name": "my-marketplace",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@marketplace/web",
    "dev:mobile": "turbo run dev --filter=@marketplace/mobile",
    "dev:api": "turbo run dev --filter=@marketplace/api",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@marketplace/api",
    "db:push": "turbo run db:push --filter=@marketplace/api"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
